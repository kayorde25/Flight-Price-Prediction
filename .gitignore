# Ignore Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore virtual environment folders
.venv/
venv/
env/

# Ignore Jupyter notebook checkpoints
.ipynb_checkpoints/

# Ignore trained model artifacts
models/*.pkl

# Ignore large local raw data files
data/raw/*.csv

# Keep placeholders
!data/raw/.gitkeep
!data/sample/.gitkeep

# Ignore OS-specific files
.DS_Store
Thumbs.db
